# AI Startup Builder — Environment Variables
# Copy this file to .env and fill in your actual keys.

# Groq API Keys (2 separate keys for parallel agent execution)
GROQ_API_KEY_AGENT1=gsk_your_key_here
GROQ_API_KEY_AGENT2=gsk_your_key_here

# Google Gemini API Key (for website generation agent)
GEMINI_API_KEY=AIza_your_key_here

# Tavily API Key (for market research web search)
TAVILY_API_KEY=tvly-your_key_here

# GitHub Personal Access Token (fallback system token)
GITHUB_TOKEN=ghp_your_token_here

# Vercel API Token (fallback system token)
VERCEL_TOKEN=vcp_your_token_here

# MongoDB Connection URL
MONGODB_URL=mongodb://localhost:27017/ai_startup_builder

# Redis Connection URL
REDIS_URL=redis://127.0.0.1:6379/0
